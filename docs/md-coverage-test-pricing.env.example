# MD Board coverage — allowlisted live payment test (Option B)
# Copy into backend admin .env and frontend Vite env (VITE_* for the app build).

# Backend (admin API)
MD_COVERAGE_TEST_PRICING_ENABLED=1
MD_COVERAGE_TEST_PROVIDER_EMAILS=your-test-provider@example.com
# Optional: comma-separated auth user ids
# MD_COVERAGE_TEST_PROVIDER_IDS=
MD_COVERAGE_TEST_MONTHLY_FEE=1

# Frontend (must match allowlist for UI display)
VITE_MD_COVERAGE_TEST_PRICING_ENABLED=1
VITE_MD_COVERAGE_TEST_PROVIDER_EMAILS=your-test-provider@example.com
VITE_MD_COVERAGE_TEST_MONTHLY_FEE=1

# After testing: set ENABLED=0 or remove vars, and cancel the test subscription in Stripe.
