{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/functions/checkExpirations",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/functions/complianceChecks",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/functions/modelAutomation",
      "schedule": "0 14 * * *"
    }
  ]
}
